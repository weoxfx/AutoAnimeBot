# ── Required ─────────────────────────────
BOT_TOKEN=           # from @BotFather
API_ID=              # from my.telegram.org
API_HASH=            # from my.telegram.org
OWNER=               # your Telegram numeric ID

# ── Optional ─────────────────────────────
MONGO_SRV=           # MongoDB connection string (for request tracking)
SESSION=             # Telethon string session (for user-account uploads if needed)
LOG_CHANNEL=         # channel ID for bot logs (e.g. -100xxxxxxxxxx)
